# Database (auto-set by Railway if using their PostgreSQL service)
DATABASE_URL=postgresql://user:password@host:5432/checkmate

# Redis (auto-set by Railway if using their Redis service)
REDIS_URL=redis://default:password@host:6379

# Auth
JWT_SECRET=generate-a-long-random-string-here
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Admin panel password
ADMIN_SECRET=choose-a-strong-password

# Frontend URL for CORS (your Vercel URL, comma-separated if multiple)
FRONTEND_URL=https://your-app.vercel.app

# Node
NODE_ENV=production
PORT=4000

# Crypto payments (leave blank to disable)
PLATFORM_WALLET_ADDRESS=
PLATFORM_WALLET_PRIVATE_KEY=
BASE_RPC_URL=
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
PLATFORM_FEE_BPS=250
